# Image sources (for Dockge/GHCR)
BACKEND_IMAGE=ghcr.io/rileyberycz/dvdflix-backend
FRONTEND_IMAGE=ghcr.io/rileyberycz/dvdflix-frontend
IMAGE_TAG=latest

# Container-internal media paths
MOVIES_PATH=/media/movies
TV_PATH=/media/tvshows
TEMP_RIP_PATH=/media/tmp

# Optional ripping devices (empty by default for portable hosts)
DRIVES=

# External services
TMDB_API_KEY=replace_me
# Use host Ollama by default. If using docker-compose.ollama.yml, set to http://ollama:11434.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_PORT=11434

# Runtime behavior
RUNTIME_TOLERANCE_MINUTES=8
MAX_IDENTIFY_WORKERS=1
DISC_CACHE_DB=/app/data/disc_cache.db

# Web app
BACKEND_HOST=0.0.0.0
BACKEND_PORT=7272
FRONTEND_PORT=7273
VITE_API_URL=http://localhost:7272
VITE_SOCKET_URL=http://localhost:7272

# Optional host paths for docker-compose.ripper.yml override
HOST_DATA_PATH=./data
HOST_MOVIES_PATH=/media/dvdflix/movies
HOST_TV_PATH=/media/dvdflix/tvshows
HOST_TEMP_RIP_PATH=/media/dvdflix/tmp

# Optional explicit drive map for docker-compose.ripper.yml
DRIVE_0=/dev/sr0
DRIVE_1=/dev/sr1
DRIVE_2=/dev/sr2

# GPU compat for Vega 11 on some Mesa stacks
HSA_OVERRIDE_GFX_VERSION=9.0.0
